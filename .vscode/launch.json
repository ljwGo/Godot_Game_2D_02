{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Game",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "/Users/ts/Desktop/Temp/m/Godot_mono.app/Contents/MacOS/Godot",
      "args": [
        "--path",
        "${workspaceFolder}"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "Attach to Godot",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}