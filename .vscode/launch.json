{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Game",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "D:\\Godot_v4.5.1-stable_mono_win64\\Godot_v4.5.1-stable_mono_win64.exe",
      "args": [
        "--path",
        "${workspaceFolder}"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "Attach to Godot",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}